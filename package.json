{
  "name": "@hitechclaw/clawspark",
  "version": "2.1.0",
  "description": "One-command OpenClaw installer and CLI for local, CPU-first, and API-backed AI agent deployments for strictly non-commercial use.",
  "author": "hitechclaw",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/thanhan92-f1/clawspark#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thanhan92-f1/clawspark.git"
  },
  "bugs": {
    "url": "https://github.com/thanhan92-f1/clawspark/issues"
  },
  "keywords": [
    "openclaw",
    "ai-agent",
    "cli",
    "ollama",
    "installer",
    "local-ai",
    "cpu-ai",
    "api-gateway",
    "non-commercial",
    "source-available"
  ],
  "bin": {
    "clawspark": "clawspark"
  },
  "files": [
    "clawspark",
    "install.sh",
    "uninstall.sh",
    "scripts",
    "lib",
    "configs",
    "v2",
    "web",
    "README.md",
    "NOTICE",
    "COMMERCIAL-LICENSE.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "bash -n ./clawspark",
    "test": "bash ./tests/run.sh",
    "pack:check": "npm pack --dry-run",
    "release:patch": "bash ./scripts/release.sh patch",
    "release:minor": "bash ./scripts/release.sh minor",
    "release:major": "bash ./scripts/release.sh major"
  },
  "preferGlobal": true,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=18"
  }
}
